#!/usr/bin/env python3
import subprocess, sys, re, shlex

diff = subprocess.run(
    ["git", "diff", "--cached"], capture_output=True, text=True
).stdout
if not diff.strip():
    diff = subprocess.run(
        ["git", "diff"], capture_output=True, text=True
    ).stdout
if not diff.strip():
    print("No changes detected", file=sys.stderr)
    sys.exit(1)

branch = subprocess.run(
    ["git", "branch", "--show-current"], capture_output=True, text=True
).stdout.strip()
m = re.search(r"[A-Z]+-\d+", branch)
prefix = m.group(0) if m else None

diff_trunc = "\n".join(diff.split("\n")[:200])

files_changed = len([
    l for l in subprocess.run(
        ["git", "diff", "--cached", "--name-only"], capture_output=True, text=True
    ).stdout.splitlines() if l.strip()
]) or len([
    l for l in subprocess.run(
        ["git", "diff", "--name-only"], capture_output=True, text=True
    ).stdout.splitlines() if l.strip()
])
large = files_changed > 3 or len(diff.splitlines()) > 100

if large:
    prompt = (
        "Generate a conventional git commit message for these changes:\n\n"
        f"{diff_trunc}\n\n"
        "Output the commit subject on line 1 (max 72 chars, conventional commit "
        "style), then a blank line, then a body with bullet points (- prefix) "
        "explaining the key changes, each line wrapped at 72 chars. "
        "Output ONLY the message text, no code fences, no extra commentary."
    )
else:
    prompt = (
        "Generate a conventional git commit message for these changes:\n\n"
        f"{diff_trunc}\n\n"
        "Output ONLY the commit subject line (max 72 chars), nothing else."
    )

result = subprocess.run(
    ["script", "-q", "-c", f"opencode run {shlex.quote(prompt)}", "/dev/null"],
    capture_output=True, text=True, timeout=60
)

ansi_re = re.compile(r'\x1b\[[0-9;]*[a-zA-Z]')
clean_lines = []
started = False
for raw in result.stdout.splitlines():
    line = ansi_re.sub('', raw).rstrip()
    stripped = line.strip()
    if stripped.startswith(">"):
        continue
    if not started:
        if not stripped or "build" in stripped.lower():
            continue
        started = True
    clean_lines.append(line.replace('`', ''))

while clean_lines and not clean_lines[-1].strip():
    clean_lines.pop()

if not clean_lines:
    sys.exit(1)

subject = clean_lines[0].strip()
header = f"{prefix} {subject}" if prefix else subject
print(header)

if large and len(clean_lines) > 1:
    body_lines = clean_lines[1:]
    while body_lines and not body_lines[0].strip():
        body_lines.pop(0)
    if body_lines:
        print()
        print("\n".join(body_lines))
