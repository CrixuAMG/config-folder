#!/usr/bin/env python3
import subprocess, sys, json, re

commit_hash = sys.argv[1] if len(sys.argv) > 1 else "HEAD"

diff = subprocess.run(
    ["git", "show", "--no-notes", "--format=", commit_hash],
    capture_output=True, text=True
).stdout or ""

if not diff.strip():
    empty_tree = subprocess.run(
        ["git", "hash-object", "-t", "tree", "/dev/null"],
        capture_output=True, text=True
    ).stdout.strip()
    diff = subprocess.run(
        ["git", "diff-tree", "--no-commit-id", "-r", "--patch",
         empty_tree, commit_hash],
        capture_output=True, text=True
    ).stdout or ""

if not diff.strip():
    print("No diff found for commit", file=sys.stderr)
    sys.exit(1)

branch = subprocess.run(
    ["git", "branch", "--show-current"], capture_output=True, text=True
).stdout.strip()
m = re.search(r"[A-Z]+-\d+", branch)
prefix = m.group(0) if m else None

diff_trunc = "\n".join(diff.split("\n")[:200])
prompt = (
    "Generate a conventional git commit message for these changes:\n\n"
    f"{diff_trunc}\n\n"
    "Output ONLY the commit subject line (max 72 chars), nothing else."
)

result = subprocess.run(
    ["script", "-q", "-c", f"opencode run {json.dumps(prompt)}", "/dev/null"],
    capture_output=True, text=True, timeout=60
)

msg = ""
for line in result.stdout.splitlines():
    line = line.strip()
    if not line or line.startswith(">") or "build" in line:
        continue
    line = line.replace("\x1b[0m", "").strip()
    if line:
        msg = line
        break

if msg:
    print(f"{prefix}: {msg}" if prefix else msg)
else:
    print("Failed to generate message", file=sys.stderr)
    sys.exit(1)
