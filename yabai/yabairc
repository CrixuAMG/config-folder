# bsp, stack or float
yabai -m config layout bsp

# next to or below the current window
yabai -m config window_placement second_child

# padding set to 6px
yabai -m config top_padding 0
yabai -m config bottom_padding 0
yabai -m config left_padding 0
yabai -m config right_padding 0
yabai -m config window_gap 6

# center mouse on window with focus
yabai -m config mouse_follows_focus on

# modifier for clicking and dragging with mouse
yabai -m config mouse_modifier alt
# set modifier + left-click drag to move window
yabai -m config mouse_action1 move
# set modifier + right-click drag to resize window
yabai -m config mouse_action2 resize


# when window is dropped in center of another window, swap them (on edges it will split it)
yabai -m mouse_drop_action swap

# enable sketchybar
yabai -m config external_bar all:32:0

# disable for these applications (manage=off = floating)
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Karabiner-Elements$" manage=off
yabai -m rule --add app="^TigerVNC Viewer$" manage=off
yabai -m rule --add app="^Spotify$" manage=off
yabai -m rule --add app="^Music$" manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^Software Update$" manage=off
yabai -m rule --add app="^App Store$" manage=off
yabai -m rule --add app="^Font Book$" manage=off
yabai -m rule --add app="^Image Capture$" manage=off
yabai -m rule --add app="^Dictionary$" manage=off
yabai -m rule --add app="^(About This Mac|AirDrop|Bluetooth|Sound|Network|Sharing|Screen Time|Extensions|General|Appearance|Control Center|Privacy|Desktop|Notifications|Wallet)$" manage=off
yabai -m rule --add app="^Photo Booth$" manage=off
yabai -m rule --add label="Finder" app="^Finder$" manage=off
yabai -m rule --add app="^System Information$" manage=off
yabai -m rule --add app="^Console$" manage=off
yabai -m rule --add app="^Disk Utility$" manage=off
yabai -m rule --add app="^ColorSync Utility$" manage=off
yabai -m rule --add app="^Script Editor$" manage=off
yabai -m rule --add app="^Grapher$" manage=off
yabai -m rule --add app="^Stickies$" manage=off
yabai -m rule --add app="^Preview$" manage=off

# focus follows mouse (autofocus: only when changing windows via mouse)
yabai -m config focus_follows_mouse autofocus

# signal: auto-float dialogs and sheets that are child windows
yabai -m signal --add event=window_created action="yabai -m window \$YABAI_WINDOW_ID --layer above" app="^System Settings$"
yabai -m signal --add event=window_created action="yabai -m window \$YABAI_WINDOW_ID --layer above" app="^Finder$"

